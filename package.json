{
  "name": "weekly-update-checker",
  "version": "0.1.2",
  "description": "Weekly checker for winget and WSL apt updates",
  "main": "./out/main/index.js",
  "author": "m.salib",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michelsalib/updater.git"
  },
  "scripts": {
    "build:icons": "node scripts/build-icons.mjs",
    "fetch:resources": "node scripts/fetch-resources.mjs",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "prebuild": "node scripts/fetch-resources.mjs",
    "build": "npm run typecheck && electron-vite build",
    "build:unpack": "npm run build && electron-builder --win --dir",
    "build:win": "npm run build && electron-builder --win",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@awesome.me/webawesome": "^3.9.0",
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.5",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "icon-gen": "^5.0.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
